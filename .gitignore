# Build artifacts
/bin/
/agent/bin/
agent/src/*.o

# Console test deps. package.json and package-lock.json are tracked so runs are
# reproducible; the installed tree is not.
node_modules/

# Runtime state (coordinator store + journals, if pointed inside the tree)
/var/
*.db
*.db-wal
*.db-shm

# Local tooling / harness settings
.claude/

# Keys / secrets — never commit
/ssh/
*.pem
id_ed25519*
id_rsa*

# Editor / OS cruft
*~
.DS_Store

# Local working notes — intentionally untracked
docs/PROJECT-SUMMARY.md
tools/fsprobe/fsprobe
tools/genfixture/genfixture
